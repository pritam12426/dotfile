CompileFlags:
  Compiler: clang
  Add:
    - "-std=c17"
    - "-pedantic"
    - "-Wall"
    - "-Wextra"
    - "-fsanitize=address,undefined"
    - "-Iinclude"
Index:
  Background: Build
  StandardLibrary: Yes


InlayHints:
  BlockEnd: false
  Designators: false
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
  TypeNameLimit: 24

Hover:
  ShowAKA: true
